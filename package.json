{
  "name": "vpnctl",
  "version": "0.1.2",
  "description": "Fail-closed macOS VPN killswitch (pf firewall + DNS sinkhole + sing-box VLESS/Reality) for AI dev tools, driven by a console CLI.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "engines": {
    "bun": ">=1.3.13"
  },
  "bin": {
    "vpnctl": "./bin/vpnctl.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "bun build --compile bin/vpnctl.ts --outfile dist/vpnctl",
    "build:monitor": "bun build --compile src/daemon/monitor.ts --outfile dist/vpnctl-monitor",
    "build:tunnel": "bun build --compile src/daemon/tunnel.ts --outfile dist/vpnctl-tunnel",
    "build:daemons": "bun run build:monitor && bun run build:tunnel"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.61.0"
  }
}
