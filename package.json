{
  "name": "vpnctl",
  "version": "0.2.5",
  "description": "Fail-closed macOS VPN killswitch (pf firewall + DNS sinkhole + sing-box VLESS/Reality) for protected domains, driven by a console CLI.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "engines": {
    "bun": ">=1.3.13"
  },
  "bin": {
    "vpnctl": "./bin/vpnctl.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "bun build --compile bin/vpnctl.ts --outfile dist/vpnctl && ./scripts/link-dist-aliases.sh",
    "build:daemons": "./scripts/link-dist-aliases.sh"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "commander": "^13.1.0",
    "ink": "^7.1.0",
    "picocolors": "^1.1.1",
    "react": "^19.2.7",
    "react-devtools-core": "^7.0.1",
    "systray2": "^2.1.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.61.0"
  }
}
